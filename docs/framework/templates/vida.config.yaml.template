project:
  id: __PROJECT_ID__
  overlay_version: 1

project_bootstrap:
  enabled: true
  docs_root: __DOCS_ROOT__
  process_root: __PROCESS_ROOT__
  research_root: __RESEARCH_ROOT__
  readme_doc: __README_DOC__
  architecture_doc: __ARCHITECTURE_DOC__
  decisions_doc: __DECISIONS_DOC__
  environments_doc: __ENVIRONMENTS_DOC__
  project_operations_doc: __PROJECT_OPERATIONS_DOC__
  agent_system_doc: __AGENT_SYSTEM_DOC__
  allow_scaffold_missing: true
  require_launch_confirmation: true

language_policy:
  user_communication: __USER_COMMUNICATION__
  reasoning: __REASONING_LANGUAGE__
  documentation: __DOCUMENTATION_LANGUAGE__
  todo_protocol: __TODO_PROTOCOL_LANGUAGE__

host_environment:
  cli_system: __HOST_CLI_SYSTEM__
  codex:
    agents: &codex_agent_catalog
      junior:
        tier: junior
        rate: 1
        reasoning_band: low
        model: gpt-5.5
        model_reasoning_effort: low
        sandbox_mode: workspace-write
        default_model_profile: codex_gpt55_low_write
        model_profiles:
          codex_gpt55_low_write:
            provider: openai
            model_ref: gpt-5.5
            reasoning_effort: low
            plan_mode_reasoning_effort: medium
            sandbox_mode: workspace-write
            normalized_cost_units: 1
            pricing:
              price_source_kind: provider_catalog
              source_paths:
                - docs/process/codex-agent-configuration-guide.md
              freshness:
                required: false
                max_age_days: 30
                stale_price_policy: diagnostic_only_use_normalized_cost_units
                missing_price_policy: diagnostic_only_use_normalized_cost_units
                diagnostic_only: true
                enforced: false
            speed_tier: fast
            quality_tier: medium
            write_scope: workspace-write
            runtime_roles:
              - worker
            task_classes:
              - implementation
              - delivery_task
              - execution_block
            readiness:
              mode: codex_profile
              required: true
        default_runtime_role: worker
        runtime_roles:
          - worker
        task_classes:
          - implementation
          - delivery_task
          - execution_block
      middle:
        tier: middle
        rate: 4
        reasoning_band: medium
        model: gpt-5.5
        model_reasoning_effort: medium
        sandbox_mode: workspace-write
        default_model_profile: codex_gpt55_medium_write
        model_profiles:
          codex_gpt55_medium_write:
            provider: openai
            model_ref: gpt-5.5
            reasoning_effort: medium
            plan_mode_reasoning_effort: high
            sandbox_mode: workspace-write
            normalized_cost_units: 4
            speed_tier: fast
            quality_tier: medium
            write_scope: workspace-write
            runtime_roles:
              - business_analyst
              - pm
              - coach
              - worker
            task_classes:
              - specification
              - planning
              - coach
              - implementation_medium
            readiness:
              mode: codex_profile
              required: true
        default_runtime_role: coach
        runtime_roles:
          - business_analyst
          - pm
          - coach
          - worker
        task_classes:
          - specification
          - planning
          - coach
          - implementation_medium
      senior:
        tier: senior
        rate: 16
        reasoning_band: high
        model: gpt-5.5
        model_reasoning_effort: high
        sandbox_mode: read-only
        default_model_profile: codex_gpt55_high_readonly
        model_profiles:
          codex_gpt55_high_readonly:
            provider: openai
            model_ref: gpt-5.5
            reasoning_effort: high
            plan_mode_reasoning_effort: high
            sandbox_mode: read-only
            normalized_cost_units: 16
            speed_tier: medium
            quality_tier: high
            write_scope: read-only
            runtime_roles:
              - verifier
              - prover
            task_classes:
              - verification
              - review
              - quality_gate
              - release_readiness
            readiness:
              mode: codex_profile
              required: true
        default_runtime_role: verifier
        runtime_roles:
          - verifier
          - prover
        task_classes:
          - verification
          - review
          - quality_gate
          - release_readiness
      architect:
        tier: architect
        rate: 48
        reasoning_band: xhigh
        model: gpt-5.5
        model_reasoning_effort: xhigh
        sandbox_mode: read-only
        default_model_profile: codex_gpt55_xhigh_arch
        model_profiles:
          codex_gpt55_high_arch:
            provider: openai
            model_ref: gpt-5.5
            reasoning_effort: high
            plan_mode_reasoning_effort: high
            sandbox_mode: read-only
            normalized_cost_units: 32
            speed_tier: medium
            quality_tier: high
            write_scope: read-only
            runtime_roles:
              - solution_architect
            task_classes:
              - architecture
              - execution_preparation
              - hard_escalation
              - meta_analysis
            readiness:
              mode: codex_profile
              required: true
          codex_gpt55_xhigh_arch:
            provider: openai
            model_ref: gpt-5.5
            reasoning_effort: xhigh
            plan_mode_reasoning_effort: xhigh
            sandbox_mode: read-only
            normalized_cost_units: 48
            speed_tier: slow
            quality_tier: very_high
            write_scope: read-only
            runtime_roles:
              - solution_architect
            task_classes:
              - hard_escalation
              - architecture
              - meta_analysis
            readiness:
              mode: codex_profile
              required: true
        default_runtime_role: solution_architect
        runtime_roles:
          - solution_architect
        task_classes:
          - architecture
          - execution_preparation
          - hard_escalation
          - meta_analysis
  systems:
    codex:
      enabled: true
      execution_class: internal
      materialization_mode: codex_toml_catalog_render
      template_root: .codex
      runtime_root: .codex
      dispatch:
        command: codex
        static_args:
          - exec
          - --json
        workdir_flag: -C
        sandbox_flag: -s
        model_flag: -m
        reasoning_effort_flag: -c
        reasoning_effort_value_template: 'model_reasoning_effort="{value}"'
        prompt_mode: positional
      carriers: *codex_agent_catalog
    qwen:
      enabled: true
      execution_class: external
      materialization_mode: copy_tree_only
      template_root: .qwen
      runtime_root: .qwen
      carriers:
        qwen-primary:
          tier: qwen
          rate: 4
          reasoning_band: medium
          default_runtime_role: worker
          runtime_roles:
            - worker
          task_classes:
            - implementation
            - research
    hermes:
      enabled: true
      execution_class: external
      materialization_mode: copy_tree_only
      template_root: .hermes
      runtime_root: .hermes
      carriers:
        hermes-primary:
          tier: hermes
          rate: 4
          reasoning_band: medium
          default_runtime_role: worker
          runtime_roles:
            - worker
          task_classes:
            - specification
            - planning
    opencode:
      enabled: true
      execution_class: external
      materialization_mode: copy_tree_only
      template_root: .opencode
      runtime_root: .opencode
      carriers:
        opencode-primary:
          tier: opencode
          rate: 4
          reasoning_band: medium
          default_runtime_role: worker
          runtime_roles:
            - worker
          task_classes:
            - implementation

protocol_activation:
  agent_system: true

agent_extensions:
  enabled: false
  map_doc: .vida/project/agent-extensions/README.md
  registries:
    roles: .vida/project/agent-extensions/roles.yaml
    skills: .vida/project/agent-extensions/skills.yaml
    profiles: .vida/project/agent-extensions/profiles.yaml
    flows: .vida/project/agent-extensions/flows.yaml
    dispatch_aliases: .vida/project/agent-extensions/dispatch-aliases.yaml
  enabled_framework_roles:
    - orchestrator
    - worker
    - business_analyst
    - pm
    - coach
    - verifier
    - prover
  enabled_standard_flow_sets:
    - minimal
  enabled_project_roles: []
  enabled_project_skills: []
  enabled_shared_skills: []
  enabled_project_profiles: []
  enabled_project_flows: []
  default_flow_set: minimal
  role_selection:
    mode: auto
    fallback_role: orchestrator
    conversation_modes:
      scope_discussion:
        enabled: true
        role: business_analyst
        single_task_only: true
        tracked_flow_entry: spec-pack
        allow_freeform_chat: true
      pbi_discussion:
        enabled: true
        role: pm
        single_task_only: true
        tracked_flow_entry: work-pool-pack
        allow_freeform_chat: true
  validation:
    require_registry_files: true
    require_unique_ids: true
    require_framework_role_compatibility: true
    require_skill_role_compatibility: true
    require_profile_resolution: true
    require_flow_resolution: true
    fail_closed_on_validation_error: true

dev_team:
  enabled: true
  contract_doc: docs/process/team-development-and-orchestration-protocol.md
  preserve_existing_agent_extensions: true
  preserve_existing_flow_sets: true
  validation:
    require_role_contracts: true
    require_flow_definitions: true
    require_runtime_role_binding: true
    require_task_class_binding: true
    require_default_carrier_binding: true
    require_handoff_contracts: true
    require_ordered_closure_flow: true
    fail_closed_on_validation_error: true
  roles:
    analyst:
      runtime_role: business_analyst
      task_classes:
        - specification
        - planning
      default_carrier: middle
      default_model: gpt-5.5
      default_model_reasoning_effort: medium
      cost_policy:
        budget_units: 4
        selection_rule: cheapest_eligible_specification_carrier
      handoff:
        next_role: developer
        required_outputs:
          - detailed_task_brief
          - architectural_context
          - bounded_problem_statement
          - acceptance_contract
          - owned_write_scope
          - stop_rules
          - duplication_risk_map
        fail_closed_on_missing_handoff: true
    developer:
      runtime_role: worker
      task_classes:
        - implementation
        - delivery_task
        - execution_block
      default_carrier: junior
      default_model: gpt-5.5
      default_model_reasoning_effort: low
      cost_policy:
        budget_units: 1
        fallback_carrier: middle
        selection_rule: cheapest_eligible_write_carrier
      handoff:
        next_role: duplication_reviewer
        required_outputs:
          - changed_files
          - verification_notes
          - residual_risks
          - explicit_blockers
        fail_closed_on_missing_handoff: true
    duplication_reviewer:
      runtime_role: verifier
      task_classes:
        - review
        - verification
        - quality_gate
      default_carrier: senior
      default_model: gpt-5.5
      default_model_reasoning_effort: high
      cost_policy:
        budget_units: 16
        selection_rule: independent_duplication_and_architecture_reuse_review
      review_contract:
        purpose: Confirm the implementation is architectural and integrated, reuses existing framework/runtime contracts, and does not duplicate code, config semantics, taskflow projections, or operator surfaces.
        required_checks:
          - shared_contract_reuse
          - duplicated_logic_scan
          - duplicated_config_schema_scan
          - existing_helper_reuse
          - architecture_boundary_integrity
          - no_dead_code_or_unwired_helpers
        fail_closed_on_duplication: true
      handoff:
        next_role: coach
        required_outputs:
          - duplication_review_report
          - reused_contracts
          - duplicate_risks
          - required_rework_or_clearance
        fail_closed_on_missing_handoff: true
    coach:
      runtime_role: coach
      task_classes:
        - coach
        - review
      default_carrier: middle
      default_model: gpt-5.5
      default_model_reasoning_effort: medium
      cost_policy:
        budget_units: 4
        selection_rule: final_spec_conformance_review_after_duplication_clearance
      handoff:
        next_role: tester
        required_outputs:
          - final_implementation_review
          - spec_conformance_review
          - rework_or_approve_decision
          - unresolved_risks
        fail_closed_on_missing_handoff: true
    tester:
      runtime_role: verifier
      task_classes:
        - verification
        - review
        - quality_gate
      default_carrier: senior
      default_model: gpt-5.5
      default_model_reasoning_effort: high
      cost_policy:
        budget_units: 16
        selection_rule: independent_verification_before_closure
      handoff:
        next_role: prover
        required_outputs:
          - verification_evidence
          - failing_or_passing_checks
          - residual_risks
        fail_closed_on_missing_handoff: true
    prover:
      runtime_role: prover
      task_classes:
        - verification
        - quality_gate
        - release_readiness
      default_carrier: senior
      default_model: gpt-5.5
      default_model_reasoning_effort: high
      cost_policy:
        budget_units: 16
        selection_rule: proof_strength_before_release
      handoff:
        next_role: release_closure
        required_outputs:
          - closure_readiness_decision
          - proof_summary
          - release_risks
        fail_closed_on_missing_handoff: true
    release_closure:
      runtime_role: prover
      task_classes:
        - release_readiness
        - quality_gate
      default_carrier: senior
      default_model: gpt-5.5
      default_model_reasoning_effort: high
      cost_policy:
        budget_units: 16
        selection_rule: fail_closed_until_release_receipt
      handoff:
        next_role: terminal_closure
        required_outputs:
          - release_or_hold_decision
          - closure_receipt
          - follow_up_actions
        fail_closed_on_missing_handoff: true
  flows:
    default_delivery:
      enabled: true
      description: System analyst produces the detailed task brief, developer implements on the cheapest write lane, duplication reviewer checks architectural reuse/no duplication, final coach reviews the completed implementation, then tester/prover gates release closure.
      sequential: true
      allow_parallel_handoffs: false
      fail_closed_on_missing_step_contract: true
      steps:
        - analyst
        - developer
        - duplication_reviewer
        - coach
        - tester
        - prover
        - release_closure

autonomous_execution:
  next_task_boundary_analysis: true
  next_task_boundary_report: brief_plan
  next_task_boundary_report_gating: false
  dependent_coverage_autoupdate: true
  agent_only_development: true

framework_self_diagnosis:
  enabled: false
  silent_mode: true
  auto_capture_bugs: true
  parent_issue: ""
  defer_fix_until_task_boundary: true
  session_reflection_required: true
  platform_direction: agentic_engineering_platform
  quality_token_efficiency: equal_weight
  session_reflection_criteria:
    - architecture_cleanliness
    - completeness
    - token_efficiency
    - orchestration_efficiency
    - instruction_clarity
    - instruction_runtime_consistency

pack_router_keywords:
  research: research
  spec: spec
  pool: pool
  pool_strong: form-task
  pool_dependency: dependency
  dev: implement
  bug: bug
  reflect: reflect
  reflect_strong: framework,self-analysis

agent_system:
  init_on_boot: true
  mode: native
  state_owner: orchestrator_only
  max_parallel_agents: 4
  routing: {}
  scoring: {}

